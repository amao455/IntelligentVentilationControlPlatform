                    <Tag color="blue" style={{ marginLeft: 4, fontWeight: 500, fontSize: 11, padding: '2px 8px' }}>远程</Tag>
                  </Col>
                  <Col span={12} style={{ textAlign: 'right' }}>
                    <Typography.Text style={{ fontSize: 11, color: '#b8d9ff' }}>
