                    <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block' }}>控制对象</Typography.Text>
                    <Typography.Text style={{ fontSize: 13, fontWeight: 600, color: '#ffffff' }}>主扇 F1</Typography.Text>
                  </Col>
                  <Col span={8}>
                    <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block' }}>控制模式</Typography.Text>
