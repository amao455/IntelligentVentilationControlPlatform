import { lazy, Suspense, useEffect, useState } from 'react';
import { Alert, Button, Card, Col, Descriptions, List, Popconfirm, Row, Space, Tag, Typography, message } from 'antd';
import {
  DashboardOutlined,
  ThunderboltOutlined,
  SafetyOutlined,
  CheckCircleOutlined,
  ClockCircleOutlined,
  WarningOutlined,
  PlayCircleOutlined,
  PoweroffOutlined,
  SwapOutlined,
  ReloadOutlined,
  ControlOutlined,
  ApiOutlined,
  FileTextOutlined,
  BellOutlined,
} from '@ant-design/icons';

interface BackgroundSettings {
  paused: boolean;
  rotationSpeed: number;
  opacity: number;
  brightness: number;
}

const DEFAULT_BG_SETTINGS: BackgroundSettings = {
  paused: false,
  rotationSpeed: 0.00,
  opacity: 0.55,
  brightness: 1.4,
};

const LazyHomeObjBackground = lazy(async () => {
  const module = await import('../../components/topology/HomeObjBackground3D');
  return { default: module.HomeObjBackground3D };
});

export default function MainFanControlPage() {
  const [api, contextHolder] = message.useMessage();
  const [bgSettings] = useState<BackgroundSettings>(DEFAULT_BG_SETTINGS);
  const [backgroundReady, setBackgroundReady] = useState(false);

  useEffect(() => {
    const timer = window.setTimeout(() => {
      setBackgroundReady(true);
    }, 350);

    return () => {
      window.clearTimeout(timer);
    };
  }, []);

  const onControlAction = (action: string) => {
    api.success(`${action} 指令已下发，等待状态回传`);
  };

  return (
    <div style={{
      position: 'relative',
      height: 'calc(100vh - 120px)',
      display: 'flex',
      flexDirection: 'column',
      overflow: 'hidden'
    }}>
      {contextHolder}

      {/* 背景三维模型 */}
      <div
        style={{
          position: 'absolute',
          inset: 0,
          zIndex: 0,
          borderRadius: '8px',
          overflow: 'hidden',
          pointerEvents: 'auto',
        }}
      >
        {backgroundReady ? (
          <Suspense
            fallback={
              <div style={{ padding: '20px', color: '#999' }}>3D背景载入中</div>
            }
          >
            <LazyHomeObjBackground
              paused={false}
              rotationSpeed={bgSettings.rotationSpeed}
              opacity={bgSettings.opacity}
              brightness={bgSettings.brightness}
              disableRotation={false}
              viewScale={4.5}
              viewAzimuthDeg={90}
            />
          </Suspense>
        ) : (
          <div style={{ padding: '20px', color: '#999' }}>正在准备巷道模型背景</div>
        )}
      </div>

      {/* 内容层 */}
      <div className="page-wrapper" style={{ position: 'relative', zIndex: 1, height: '100%', display: 'flex', flexDirection: 'column', overflow: 'hidden', padding: '12px', pointerEvents: 'none' }}>

      {/* 上半部分 - 占 3/4 */}
      <Row gutter={[12, 12]} style={{ flex: 3, minHeight: 0, marginBottom: 10, pointerEvents: 'none' }}>
        {/* 右侧：运行总览与控制操作 */}
        <Col span={6} style={{ height: '100%', display: 'flex', flexDirection: 'column', overflow: 'hidden', gap: '10px', marginLeft: 'auto', pointerEvents: 'auto' }}>
          {/* 1. 主风机运行总览卡片 */}
          <Card
            className="page-card"
            size="small"
            title={
              <div style={{ display: 'flex', alignItems: 'center', gap: 8 }}>
                <DashboardOutlined style={{ fontSize: 15, color: '#69c0ff' }} />
                <span style={{ fontSize: 13, fontWeight: 700, color: '#ffffff', textShadow: '0 0 15px rgba(156, 208, 255, 0.6), 0 2px 4px rgba(0, 0, 0, 0.3)' }}>主风机运行总览</span>
              </div>
            }
            style={{
              flex: '0 0 auto',
              background: 'transparent',
              border: '2px solid rgba(150, 205, 255, 0.5)',
              boxShadow: '0 4px 20px rgba(11, 35, 62, 0.6), 0 0 30px rgba(74, 157, 232, 0.15), inset 0 1px 0 rgba(196, 225, 255, 0.2)',
              backdropFilter: 'blur(16px)',
              transition: 'all 0.3s ease'
            }}
            headStyle={{
              background: 'linear-gradient(180deg, rgba(89, 154, 221, 0.2) 0%, rgba(89, 154, 221, 0.1) 100%)',
              borderBottom: '2px solid rgba(150, 205, 255, 0.5)',
              padding: '8px 12px',
              minHeight: 'auto'
            }}
            bodyStyle={{ padding: '10px 12px', background: 'transparent' }}
          >
              <Space direction="vertical" size={8} style={{ width: '100%' }}>
                {/* 主风机编号和状态 */}
                <Row gutter={8}>
                  <Col span={12}>
                    <div style={{
                      padding: '8px 10px',
                      background: 'rgba(89, 154, 221, 0.15)',
                      borderRadius: 4,
                      border: '1px solid rgba(150, 205, 255, 0.3)'
                    }}>
                      <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block', marginBottom: 3 }}>
                        <ApiOutlined style={{ fontSize: 11, marginRight: 4 }} />
                        运行主风机
                      </Typography.Text>
                      <Typography.Text style={{ fontSize: 14, fontWeight: 700, color: '#ffffff', textShadow: '0 0 10px rgba(156, 208, 255, 0.6)' }}>
                        主扇 F1
                      </Typography.Text>
                    </div>
                  </Col>
                  <Col span={12}>
                    <div style={{
                      padding: '8px 10px',
                      background: 'rgba(82, 196, 26, 0.15)',
                      borderRadius: 4,
                      border: '1px solid rgba(82, 196, 26, 0.4)'
                    }}>
                      <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block', marginBottom: 3 }}>
                        <CheckCircleOutlined style={{ fontSize: 11, marginRight: 4 }} />
                        运行状态
                      </Typography.Text>
                      <Tag color="success" style={{ fontSize: 12, fontWeight: 600, padding: '2px 10px' }}>
                        <CheckCircleOutlined style={{ fontSize: 11, marginRight: 4 }} />
                        正常运行
                      </Tag>
                    </div>
                  </Col>
                </Row>

                {/* 关键运行参数 */}
                <div style={{
                  padding: '8px 10px',
                  background: 'rgba(89, 154, 221, 0.1)',
                  borderRadius: 4,
                  border: '1px solid rgba(150, 205, 255, 0.25)'
                }}>
                  <Row gutter={[8, 6]}>
                    <Col span={12}>
                      <div>
                        <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block' }}>风量</Typography.Text>
                        <Typography.Text style={{ fontSize: 14, fontWeight: 700, color: '#52c41a' }}>
                          1850 <span style={{ fontSize: 11, fontWeight: 400, color: '#b8d9ff' }}>m³/min</span>
                        </Typography.Text>
                      </div>
                    </Col>
                    <Col span={12}>
                      <div>
                        <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block' }}>负压</Typography.Text>
                        <Typography.Text style={{ fontSize: 14, fontWeight: 700, color: '#1890ff' }}>
                          2850 <span style={{ fontSize: 11, fontWeight: 400, color: '#b8d9ff' }}>Pa</span>
                        </Typography.Text>
                      </div>
                    </Col>
                    <Col span={12}>
                      <div>
                        <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block' }}>电机功率</Typography.Text>
                        <Typography.Text style={{ fontSize: 14, fontWeight: 700, color: '#faad14' }}>
                          1250 <span style={{ fontSize: 11, fontWeight: 400, color: '#b8d9ff' }}>kW</span>
                        </Typography.Text>
                      </div>
                    </Col>
                    <Col span={12}>
                      <div>
                        <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block' }}>轴承温度</Typography.Text>
                        <Typography.Text style={{ fontSize: 14, fontWeight: 700, color: '#ff7a45' }}>
                          68 <span style={{ fontSize: 11, fontWeight: 400, color: '#b8d9ff' }}>℃</span>
                        </Typography.Text>
                      </div>
                    </Col>
                  </Row>
                </div>

                {/* 控制模式和更新时间 */}
                <Row gutter={8}>
                  <Col span={12}>
                    <Typography.Text style={{ fontSize: 11, color: '#b8d9ff' }}>
