                        boxShadow: '0 0 6px rgba(82, 196, 26, 0.6)'
                      }} />
                      <Typography.Text style={{ fontSize: 12, color: '#52c41a', fontWeight: 600 }}>
                        100%
                      </Typography.Text>
                    </Space>
                  </div>

                  {/* 电气保护 */}
                  <div style={{
                    padding: '6px 8px',
                    background: 'rgba(89, 154, 221, 0.1)',
                    borderRadius: 4,
                    border: '1px solid rgba(150, 205, 255, 0.25)',
                    display: 'flex',
                    justifyContent: 'space-between',
                    alignItems: 'center'
                  }}>
                    <Typography.Text style={{ fontSize: 12, color: '#e8f4ff' }}>
                      电气保护装置
                    </Typography.Text>
                    <Space size={4}>
                      <div style={{
                        width: 7,
                        height: 7,
                        borderRadius: '50%',
                        background: '#52c41a',
                        boxShadow: '0 0 6px rgba(82, 196, 26, 0.6)'
                      }} />
                      <Typography.Text style={{ fontSize: 12, color: '#52c41a', fontWeight: 600 }}>
                        正常
                      </Typography.Text>
                    </Space>
                  </div>

                  {/* 故障闭锁 */}
                  <div style={{
                    padding: '6px 8px',
                    background: 'rgba(89, 154, 221, 0.1)',
                    borderRadius: 4,
                    border: '1px solid rgba(150, 205, 255, 0.25)',
                    display: 'flex',
                    justifyContent: 'space-between',
                    alignItems: 'center'
                  }}>
                    <Typography.Text style={{ fontSize: 12, color: '#e8f4ff' }}>
                      故障闭锁状态
                    </Typography.Text>
                    <Space size={4}>
                      <div style={{
                        width: 7,
                        height: 7,
                        borderRadius: '50%',
                        background: '#52c41a',
                        boxShadow: '0 0 6px rgba(82, 196, 26, 0.6)'
                      }} />
                      <Typography.Text style={{ fontSize: 12, color: '#52c41a', fontWeight: 600 }}>
                        无闭锁
                      </Typography.Text>
                    </Space>
                  </div>
                </Space>
              </div>

              {/* 综合评估 */}
              <div style={{
                padding: '8px 10px',
                background: 'rgba(82, 196, 26, 0.15)',
                borderRadius: 4,
                border: '1px solid rgba(82, 196, 26, 0.4)',
                textAlign: 'center'
              }}>
                <Typography.Text style={{ fontSize: 12, color: '#ffffff', fontWeight: 600 }}>
                  联锁检查结果：
                </Typography.Text>
                <Tag color="success" style={{ fontSize: 12, fontWeight: 600, marginLeft: 8, padding: '2px 12px' }}>
                  全部通过 ✓
                </Tag>
              </div>
            </Space>
          </Card>
        </Col>
      </Row>

      {/* 下半部分 - 占 1/4 */}
      <Row gutter={[12, 12]} style={{ flex: 1, minHeight: 0, flexShrink: 0, pointerEvents: 'none' }}>
        {/* 4. 反馈状态卡片 */}
        <Col span={12} style={{ height: '100%', pointerEvents: 'auto' }}>
          <Card
            className="page-card"
            size="small"
            title={<span style={{ fontSize: 13, fontWeight: 700, color: '#ffffff', textShadow: '0 0 15px rgba(156, 208, 255, 0.6), 0 2px 4px rgba(0, 0, 0, 0.3)' }}>指令反馈状态</span>}
            style={{
              height: '100%',
              display: 'flex',
              flexDirection: 'column',
              background: 'transparent',
              border: '2px solid rgba(156, 39, 176, 0.6)',
              boxShadow: '0 4px 20px rgba(11, 35, 62, 0.6), 0 0 30px rgba(156, 39, 176, 0.2), inset 0 1px 0 rgba(206, 147, 216, 0.2)',
              backdropFilter: 'blur(16px)',
              transition: 'all 0.3s ease'
            }}
            headStyle={{
              background: 'linear-gradient(180deg, rgba(156, 39, 176, 0.25) 0%, rgba(156, 39, 176, 0.15) 100%)',
              borderBottom: '2px solid rgba(156, 39, 176, 0.5)',
              padding: '8px 12px',
              minHeight: 'auto'
            }}
            bodyStyle={{ padding: '10px 12px', background: 'transparent', flex: 1, display: 'flex', flexDirection: 'column', overflow: 'hidden' }}
          >
            <style>{`
              .feedback-card-body::-webkit-scrollbar {
                display: none;
              }
            `}</style>
            <Space direction="vertical" size={8} style={{ width: '100%', height: '100%', overflow: 'auto' }} className="feedback-card-body">
              {/* 最近指令 */}
              <div style={{
                padding: '8px 10px',
                background: 'rgba(156, 39, 176, 0.15)',
                borderRadius: 4,
                border: '1px solid rgba(156, 39, 176, 0.4)'
              }}>
                <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block', marginBottom: 3 }}>
                  最近控制指令
                </Typography.Text>
                <Typography.Text style={{ fontSize: 14, fontWeight: 700, color: '#ffffff', textShadow: '0 0 8px rgba(156, 208, 255, 0.5)' }}>
                  启动主扇 F1
                </Typography.Text>
              </div>

              {/* 执行状态 */}
              <Row gutter={8}>
                <Col span={12}>
                  <div style={{
                    padding: '8px 10px',
                    background: 'rgba(89, 154, 221, 0.1)',
                    borderRadius: 4,
                    border: '1px solid rgba(150, 205, 255, 0.25)'
                  }}>
                    <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block' }}>执行结果</Typography.Text>
                    <Tag color="success" style={{ fontSize: 12, fontWeight: 600, marginTop: 3, padding: '2px 10px' }}>成功</Tag>
                  </div>
                </Col>
                <Col span={12}>
                  <div style={{
                    padding: '8px 10px',
                    background: 'rgba(89, 154, 221, 0.1)',
                    borderRadius: 4,
                    border: '1px solid rgba(150, 205, 255, 0.25)'
                  }}>
                    <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block' }}>执行进度</Typography.Text>
                    <Typography.Text style={{ fontSize: 14, fontWeight: 600, color: '#52c41a', marginTop: 3, display: 'block' }}>
                      100%
                    </Typography.Text>
                  </div>
                </Col>
              </Row>

              {/* 指令详情 */}
              <div style={{
                padding: '8px 10px',
                background: 'rgba(89, 154, 221, 0.1)',
                borderRadius: 4,
                border: '1px solid rgba(150, 205, 255, 0.25)'
              }}>
                <Space direction="vertical" size={4} style={{ width: '100%' }}>
                  <Row justify="space-between">
                    <Col>
                      <Typography.Text style={{ fontSize: 11, color: '#b8d9ff' }}>下发时间</Typography.Text>
                    </Col>
                    <Col>
                      <Typography.Text style={{ fontSize: 11, color: '#e8f4ff', fontWeight: 500 }}>14:30:08</Typography.Text>
                    </Col>
                  </Row>
                  <Row justify="space-between">
                    <Col>
                      <Typography.Text style={{ fontSize: 11, color: '#b8d9ff' }}>完成时间</Typography.Text>
                    </Col>
                    <Col>
                      <Typography.Text style={{ fontSize: 11, color: '#e8f4ff', fontWeight: 500 }}>14:30:45</Typography.Text>
                    </Col>
                  </Row>
                  <Row justify="space-between">
                    <Col>
                      <Typography.Text style={{ fontSize: 11, color: '#b8d9ff' }}>执行耗时</Typography.Text>
                    </Col>
                    <Col>
                      <Typography.Text style={{ fontSize: 11, color: '#52c41a', fontWeight: 600 }}>37 秒</Typography.Text>
                    </Col>
                  </Row>
                </Space>
              </div>

              {/* 反馈状态值 */}
              <div style={{
                padding: '8px 10px',
                background: 'rgba(89, 154, 221, 0.1)',
                borderRadius: 4,
                border: '1px solid rgba(150, 205, 255, 0.25)'
              }}>
                <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block', marginBottom: 4 }}>
                  当前状态反馈
                </Typography.Text>
                <Space size={6} wrap>
                  <Tag color="processing" style={{ fontSize: 11, padding: '2px 8px' }}>运行中</Tag>
                  <Typography.Text style={{ fontSize: 11, color: '#e8f4ff' }}>频率 48.5Hz</Typography.Text>
                  <Typography.Text style={{ fontSize: 11, color: '#e8f4ff' }}>风量 1850m³/min</Typography.Text>
                </Space>
              </div>

              {/* 异常提示 */}
              <div style={{
                padding: '6px 8px',
                background: 'rgba(82, 196, 26, 0.1)',
                borderRadius: 4,
                border: '1px solid rgba(82, 196, 26, 0.3)',
                textAlign: 'center'
              }}>
                <Space size={6}>
                  <div style={{
                    width: 7,
                    height: 7,
                    borderRadius: '50%',
                    background: '#52c41a',
                    boxShadow: '0 0 6px rgba(82, 196, 26, 0.6)'
                  }} />
                  <Typography.Text style={{ fontSize: 11, color: '#52c41a', fontWeight: 600 }}>
                    无异常
                  </Typography.Text>
                </Space>
              </div>
            </Space>
          </Card>
        </Col>

        {/* 5. 运行告警与操作记录卡片 */}
        <Col span={12} style={{ height: '100%', pointerEvents: 'auto' }}>
          <Card
            className="page-card"
            size="small"
            title={<span style={{ fontSize: 13, fontWeight: 700, color: '#ffffff', textShadow: '0 0 15px rgba(156, 208, 255, 0.6), 0 2px 4px rgba(0, 0, 0, 0.3)' }}>运行告警与操作记录</span>}
            style={{
              height: '100%',
              display: 'flex',
              flexDirection: 'column',
              background: 'transparent',
              border: '2px solid rgba(255, 152, 0, 0.6)',
              boxShadow: '0 4px 20px rgba(11, 35, 62, 0.6), 0 0 30px rgba(255, 152, 0, 0.2), inset 0 1px 0 rgba(255, 204, 128, 0.2)',
              backdropFilter: 'blur(16px)',
              transition: 'all 0.3s ease'
            }}
            headStyle={{
              background: 'linear-gradient(180deg, rgba(255, 152, 0, 0.25) 0%, rgba(255, 152, 0, 0.15) 100%)',
              borderBottom: '2px solid rgba(255, 152, 0, 0.5)',
              padding: '8px 12px',
              minHeight: 'auto'
            }}
            bodyStyle={{ padding: '10px 12px', flex: 1, overflow: 'hidden', background: 'transparent', display: 'flex', flexDirection: 'column' }}
          >
            <style>{`
              .alarm-card-section::-webkit-scrollbar {
                width: 0 !important;
                height: 0 !important;
                display: none !important;
              }
              .alarm-card-section {
                scrollbar-width: none !important;
                -ms-overflow-style: none !important;
              }
              .alarm-card-section .ant-list {
                overflow: visible !important;
              }
            `}</style>
            <div style={{ display: 'flex', flexDirection: 'column', gap: '8px', flex: 1, minHeight: 0, overflow: 'hidden' }}>
              {/* 当前告警 */}
              <div style={{ flex: 1, minHeight: 0, display: 'flex', flexDirection: 'column' }}>
                <Row justify="space-between" align="middle" style={{ marginBottom: 6 }}>
                  <Col>
                    <Typography.Text strong style={{ fontSize: 12, color: '#ffffff' }}>当前告警</Typography.Text>
                  </Col>
                  <Col>
                    <Tag color="orange" style={{ fontSize: 11, padding: '2px 8px', margin: 0 }}>1 条</Tag>
                  </Col>
                </Row>
                <div style={{
                  flex: 1,
                  minHeight: 0,
                  overflowY: 'auto',
                  scrollbarWidth: 'none',
                  msOverflowStyle: 'none'
                }} className="alarm-card-section">
                  <List
                    size="small"
                    dataSource={[
                      { level: 'warning', message: '主扇 F1 轴承温度偏高', value: '68℃', time: '14:25' },
                      { level: 'info', message: '主扇 F2 处于备用状态', value: '待命', time: '14:20' },
                    ]}
                    renderItem={(item) => (
                      <List.Item style={{
                        padding: '6px 8px',
                        marginBottom: 4,
                        background: item.level === 'warning' ? 'rgba(255, 152, 0, 0.1)' : 'rgba(89, 154, 221, 0.1)',
                        borderRadius: 4,
                        border: `1px solid ${item.level === 'warning' ? 'rgba(255, 152, 0, 0.3)' : 'rgba(150, 205, 255, 0.25)'}`,
                        display: 'block'
                      }}>
                        <Row justify="space-between" align="middle" style={{ marginBottom: 3 }}>
                          <Col>
                            <Space size={4}>
                              <div style={{
                                width: 6,
                                height: 6,
                                borderRadius: '50%',
                                background: item.level === 'warning' ? '#ff9800' : '#1890ff',
                                boxShadow: `0 0 4px ${item.level === 'warning' ? 'rgba(255, 152, 0, 0.6)' : 'rgba(24, 144, 255, 0.6)'}`
                              }} />
                              <Tag color={item.level === 'warning' ? 'orange' : 'blue'} style={{ fontSize: 11, padding: '2px 8px', margin: 0 }}>
                                {item.level === 'warning' ? '告警' : '信息'}
                              </Tag>
                            </Space>
                          </Col>
                          <Col>
                            <Typography.Text style={{ fontSize: 11, color: '#b8d9ff' }}>{item.time}</Typography.Text>
                          </Col>
                        </Row>
                        <Typography.Text style={{ fontSize: 12, color: '#e8f4ff', display: 'block' }}>
                          {item.message}
                        </Typography.Text>
                        {item.value && (
                          <Typography.Text style={{
                            fontSize: 11,
                            color: item.level === 'warning' ? '#ff9800' : '#1890ff',
                            fontWeight: 600,
                            display: 'block',
                            marginTop: 2
                          }}>
                            当前值：{item.value}
                          </Typography.Text>
                        )}
                      </List.Item>
                    )}
                  />
                </div>
              </div>

              {/* 最近操作记录 */}
              <div style={{ flex: 1, minHeight: 0, display: 'flex', flexDirection: 'column' }}>
                <Row justify="space-between" align="middle" style={{ marginBottom: 6 }}>
                  <Col>
                    <Typography.Text strong style={{ fontSize: 12, color: '#ffffff' }}>最近操作</Typography.Text>
                  </Col>
                  <Col>
                    <Tag color="blue" style={{ fontSize: 11, padding: '2px 8px', margin: 0 }}>2 条</Tag>
                  </Col>
                </Row>
                <div style={{
                  flex: 1,
                  minHeight: 0,
                  overflowY: 'auto',
                  scrollbarWidth: 'none',
                  msOverflowStyle: 'none'
                }} className="alarm-card-section">
                  <List
                    size="small"
                    dataSource={[
                      { operator: '张工', action: '启动主扇 F1', result: '成功', time: '14:30', duration: '37秒' },
                      { operator: '李工', action: '停止主扇 F2', result: '成功', time: '14:15', duration: '2分15秒' },
                    ]}
                    renderItem={(item) => (
                      <List.Item style={{
                        padding: '6px 8px',
                        marginBottom: 4,
                        background: 'rgba(89, 154, 221, 0.1)',
                        borderRadius: 4,
                        border: '1px solid rgba(150, 205, 255, 0.25)',
                        display: 'block'
                      }}>
                        <Row justify="space-between" align="middle" style={{ marginBottom: 3 }}>
                          <Col>
                            <Space size={4}>
                              <Typography.Text style={{ fontSize: 12, fontWeight: 600, color: '#ffffff' }}>
                                {item.operator}
                              </Typography.Text>
                              <Tag color={item.result === '成功' ? 'success' : 'error'} style={{ fontSize: 11, padding: '2px 8px', margin: 0 }}>
                                {item.result}
                              </Tag>
                            </Space>
                          </Col>
                          <Col>
                            <Typography.Text style={{ fontSize: 11, color: '#b8d9ff' }}>{item.time}</Typography.Text>
                          </Col>
                        </Row>
                        <Typography.Text style={{ fontSize: 12, color: '#e8f4ff', display: 'block' }}>
                          {item.action}
                        </Typography.Text>
                        <Typography.Text style={{ fontSize: 11, color: '#b8d9ff', display: 'block', marginTop: 2 }}>
                          耗时：{item.duration}
                        </Typography.Text>
                      </List.Item>
                    )}
                  />
                </div>
              </div>
            </div>
          </Card>
        </Col>
      </Row>
      </div>
    </div>
  );
}
