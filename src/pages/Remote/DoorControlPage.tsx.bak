                          fontWeight: 600,
                          fontSize: 13,
                          boxShadow: '0 2px 8px rgba(255, 77, 79, 0.3)'
                        }}
                      >
                        停止
                      </Button>
                    </Popconfirm>
                  </Col>
                </Row>
              </div>

              {/* 高级操作 */}
              <div>
                <Typography.Text style={{ fontSize: 12, color: '#ffffff', fontWeight: 600, display: 'block', marginBottom: 8 }}>
                  高级操作
                </Typography.Text>
                <Row gutter={[8, 8]}>
                  <Col span={12}>
                    <Popconfirm
                      title="确认执行主备切换？"
                      description={
                        <div style={{ fontSize: 12 }}>
                          <div>• 将从主扇 F1 切换至主扇 F2</div>
